@page "/Movies"
@using KeepTrack.BlazorApp.Components.Inventory.Clients
@inject MoviesApiClient Api
@inject NavigationManager Nav
@rendermode InteractiveServer
@attribute [Authorize]

<PageTitle>My Movies</PageTitle>

@if (_error is not null)
{
    <div class="alert alert-danger mb-4" role="alert">@_error</div>
}

@if (_showForm)
{
    <div class="kt-form-card">
        <h5>@(_editing is null ? "New movie" : "Edit movie")</h5>
        <div class="row g-3">
            <div class="col-md-5">
                <label class="form-label">Title</label>
                <input class="form-control" placeholder="e.g. Terminator" @bind="_form.Title" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Year</label>
                <input class="form-control" placeholder="2001" type="number" @bind="_form.Year" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Genre</label>
                <input class="form-control" placeholder="e.g. Mystery" @bind="_form.Genre" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Rating</label>
                <select class="form-select" @bind="_form.Rating">
                    <option value="0">—</option>
                    @for (var i = 1; i <= 5; i++)
                    {
                        <option value="@i">@(new string('★', i))</option>
                    }
                </select>
            </div>
            <div class="col-12">
                <label class="form-label">Notes</label>
                <input class="form-control" placeholder="What did you think?" @bind="_form.Notes" />
            </div>
            <div class="col-12 d-flex gap-2 pt-1">
                <button class="btn btn-success" @onclick="SaveAsync">Save</button>
                <button class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
            </div>
        </div>
    </div>
}

@if (_loading)
{
    <div class="kt-loading">
        <div class="kt-spinner"></div>
        Loading your collection…
    </div>
}
else if (_movies.Count == 0 && !_showForm)
{
    <div class="kt-table-wrap">
        <div class="kt-table-header">
            <h1 class="kt-table-title">My <span>Movies</span></h1>
            <button class="btn btn-primary" @onclick="ShowAddForm">+ Add movie</button>
        </div>
        <div class="kt-empty">
            <div class="kt-empty-icon">◈</div>
            <p>Your collection is empty.<br/>Add the first film you remember loving.</p>
        </div>
    </div>
}
else if (_movies.Count > 0)
{
    <div class="kt-table-wrap">
        <div class="kt-table-header">
            <h1 class="kt-table-title">My <span>Movies</span></h1>
            @if (!_showForm)
            {
                <button class="btn btn-primary" @onclick="ShowAddForm">+ Add movie</button>
            }
        </div>
        <div class="kt-search-bar">
            <div class="kt-search-input-wrap">
                <input class="form-control"
                       type="search"
                       placeholder="Search by title, genre…"
                       @bind="_search"
                       @bind:event="oninput"
                       @onkeyup="OnSearchKeyUp" />
                <span class="kt-search-icon">&#128269;</span>
            </div>
            @if (!string.IsNullOrEmpty(_search))
            {
                <button class="btn btn-secondary btn-sm" @onclick="ClearSearch">Clear</button>
            }
        </div>
        <table class="table">
            <thead>
            <tr>
                <th>Title</th>
                <th>Year</th>
                <th>Genre</th>
                <th>Rating</th>
                <th>Notes</th>
                <th style="width:120px"></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var movie in _movies)
            {
                    @if (_editingInline?.Id == movie.Id)
                    {
                        <tr class="kt-editing">
                            <td><input class="form-control form-control-sm" @bind="_inlineForm.Title" /></td>
                            <td><input class="form-control form-control-sm" type="number" @bind="_inlineForm.Year" style="width:80px" /></td>
                            <td><input class="form-control form-control-sm" @bind="_inlineForm.Genre" /></td>
                            <td>
                                <select class="form-select form-select-sm" @bind="_inlineForm.Rating" style="width:80px">
                                    <option value="0">—</option>
                                @for (var i = 1; i <= 5; i++)
                                {
                                    <option value="@i">@(new string('★', i))</option>
                                    }
                                </select>
                            </td>
                            <td><input class="form-control form-control-sm" @bind="_inlineForm.Notes" /></td>
                            <td>
                                <div class="d-flex gap-1">
                                    <button class="btn btn-sm btn-success" @onclick="SaveInlineAsync">Save</button>
                                <button class="btn btn-sm btn-secondary" @onclick="CancelInline">✕</button>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td style="font-weight:500">@movie.Title</td>
                        <td style="color:var(--kt-text-muted)">@(movie.Year > 0 ? movie.Year : "—")</td>
                        <td style="color:var(--kt-text-muted)">@(string.IsNullOrEmpty(movie.Genre) ? "—" : movie.Genre)</td>
                        <td>
                                @if (movie.Rating > 0)
                                {
                                    <span class="kt-stars">
                                        @(new string('★', movie.Rating ?? 0))<span class="empty">@(new string('★', 5 - (movie.Rating ?? 0)))</span>
                                    </span>
                                }
                                else
                            {
                                <span style="color:var(--kt-text-subtle)">—</span>
                            }
                        </td>
                        <td style="color:var(--kt-text-muted); font-size:0.85rem">@(string.IsNullOrEmpty(movie.Notes) ? "—" : movie.Notes)</td>
                        <td>
                            <div class="d-flex gap-1">
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => StartInlineEdit(movie)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(movie.Id!)">Del</button>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>

        @if (TotalPages > 1)
        {
            <div class="kt-pagination">
                <button class="kt-page-btn" disabled="@(_page == 1)" @onclick="() => GoToPage(_page - 1)">&#8592;</button>

                @for (var p = 1; p <= TotalPages; p++)
                {
                    var pageNum = p;
                    <button class="kt-page-btn @(pageNum == _page ? "active" : "")"
                            @onclick="() => GoToPage(pageNum)">@pageNum</button>
                }

                <button class="kt-page-btn" disabled="@(_page == TotalPages)" @onclick="() => GoToPage(_page + 1)">&#8594;</button>

                <span class="kt-page-info">@_totalCount results</span>
            </div>
        }
    </div>
}

@code {
    private const int PageSize = 20;
    private List<MovieDto> _movies = [];
    private MovieDto _form = new();
    private MovieDto? _editing;
    private MovieDto? _editingInline;
    private MovieDto _inlineForm = new();
    private bool _showForm;
    private bool _loading = true;
    private string? _error;
    private string _search = "";
    private int _page = 1;
    private long _totalCount = 0;
    private int TotalPages => (int)Math.Ceiling(_totalCount / (double)PageSize);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        try
        {
            _loading = true;
             var result   = await Api.GetAsync(_search, _page, PageSize);
            _movies      = result.Items;
            _totalCount  = result.TotalCount;
        }
        catch (TokenExpiredException)
        {
            Nav.NavigateTo("/Account/Login", forceLoad: true);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchAsync();
    }

    private async Task SearchAsync()
    {
        _page = 1;
        await LoadAsync();
    }

    private async Task ClearSearch()
    {
        _search = "";
        _page = 1;
        await LoadAsync();
    }

    private async Task GoToPage(int page)
    {
        _page = page;
        await LoadAsync();
    }

    private void ShowAddForm()
    {
        _editing = null;
        _form = new MovieDto();
        _showForm = true;
        _editingInline = null;
    }

    private void CancelForm()
    {
        _showForm = false;
        _error = null;
    }

    private async Task SaveAsync()
    {
        try
        {
            if (_editing is null) await Api.AddAsync(_form);
            else await Api.UpdateAsync(_form);
            _showForm = false;
            await LoadAsync();
        }
        catch (TokenExpiredException)
        {
            Nav.NavigateTo("/Account/Login", forceLoad: true);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void StartInlineEdit(MovieDto movie)
    {
        _showForm = false;
        _editingInline = movie;
        _inlineForm = new MovieDto
        {
            Id = movie.Id,
            Title = movie.Title,
            Year = movie.Year,
            Genre = movie.Genre,
            Rating = movie.Rating,
            Notes = movie.Notes
        };
    }

    private void CancelInline()
    {
        _editingInline = null;
        _error = null;
    }

    private async Task SaveInlineAsync()
    {
        try
        {
            await Api.UpdateAsync(_inlineForm);
            _editingInline = null;
            await LoadAsync();
        }
        catch (TokenExpiredException)
        {
            Nav.NavigateTo("/Account/Login", forceLoad: true);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task DeleteAsync(string id)
    {
        try
        {
            await Api.DeleteAsync(id);
            await LoadAsync();
        }
        catch (TokenExpiredException)
        {
            Nav.NavigateTo("/Account/Login", forceLoad: true);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
