@page "/account/manage"
@attribute [Authorize]
@inject UserPreferencesState PreferencesState

<h1>Manage</h1>
<AuthorizeView>
    <Authorized>
        <h3>Hello, @context.User.Identity!.Name!</h3>
        <p class="lead">
            Signed in as <strong>@context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</strong>
        </p>
    </Authorized>
</AuthorizeView>

@if (_preferences is not null)
{
    <h3 class="mt-4">Preferences</h3>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="pref-chasse-aux-livres-link"
               checked="@_preferences.Features.ShowChasseAuxLivresLink" @onchange="e => SetFeatureAsync((f, v) => f.ShowChasseAuxLivresLink = v, (bool)e.Value!)"/>
        <label class="form-check-label" for="pref-chasse-aux-livres-link">
            Show chasse-aux-livres.fr link on book pages
        </label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="pref-amazon-product-link"
               checked="@_preferences.Features.ShowAmazonProductLink" @onchange="e => SetFeatureAsync((f, v) => f.ShowAmazonProductLink = v, (bool)e.Value!)"/>
        <label class="form-check-label" for="pref-amazon-product-link">
            Show Amazon product link on owned copies imported from Amazon
        </label>
    </div>
}

@code {
    private UserPreferencesDto? _preferences;

    protected override async Task OnInitializedAsync()
    {
        _preferences = await PreferencesState.GetAsync();
    }

    private async Task SetFeatureAsync(Action<UserPreferencesFeaturesDto, bool> apply, bool value)
    {
        if (_preferences is null) return;
        apply(_preferences.Features, value);
        await PreferencesState.UpdateAsync(_preferences);
    }
}
