@page "/account/manage"
@attribute [Authorize]
@inject UserPreferencesApiClient PreferencesApi

<h1>Manage</h1>
<AuthorizeView>
    <Authorized>
        <h3>Hello, @context.User.Identity!.Name!</h3>
        <p class="lead">
            Signed in as <strong>@context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</strong>
        </p>
    </Authorized>
</AuthorizeView>

@if (_preferences is not null)
{
    <h3 class="mt-4">Preferences</h3>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="pref-chasse-aux-livres-link"
               checked="@_preferences.ShowChasseAuxLivresLink" @onchange="e => SetShowChasseAuxLivresLinkAsync((bool)e.Value!)"/>
        <label class="form-check-label" for="pref-chasse-aux-livres-link">
            Show chasse-aux-livres.fr link on book pages
        </label>
    </div>
}

@code {
    private UserPreferencesDto? _preferences;

    protected override async Task OnInitializedAsync()
    {
        _preferences = await PreferencesApi.GetAsync();
    }

    private async Task SetShowChasseAuxLivresLinkAsync(bool value)
    {
        if (_preferences is null) return;
        _preferences.ShowChasseAuxLivresLink = value;
        await PreferencesApi.UpdateAsync(_preferences);
    }
}
