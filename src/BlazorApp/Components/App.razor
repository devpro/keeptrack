@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <base href="/"/>
    <ResourcePreloader/>
    <script src="@Assets["theme.js"]"></script>
    <script src="@Assets["download.js"]"></script>
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]"/>
    <link rel="stylesheet" href="@Assets["app.css"]"/>
    <link rel="stylesheet" href="@Assets["Keeptrack.BlazorApp.styles.css"]"/>
    <ImportMap/>
    <link rel="icon" type="image/png" href="favicon.png"/>
    <HeadOutlet/>
</head>

<body>
<Routes/>
<ReconnectModal/>
<FirebaseSessionRefresh/>
@if (Configuration.GetValue("Features:IsWebSocketsOnlyEnabled", true))
{
    @* The circuit runs on a single WebSocket with no negotiate round-trip, so it naturally pins to the
       one server instance that owns its state - the only way multiple replicas work behind a plain
       Kubernetes Service (cloudflared, or any proxy without cookie affinity). Reconnects after a network
       blip open a fresh WebSocket that may land on another replica; each retry re-rolls, so with the
       default retry count the odds of never reaching the right replica are negligible at small replica
       counts. The flag (default on) exists for a proxy that can't pass WebSockets through - such a
       deployment must stay single-replica. transport: 1 is HttpTransportType.WebSockets. *@
    <script src="@Assets["_framework/blazor.web.js"]" autostart="false"></script>
    <script>
        Blazor.start({
            circuit: {
                configureSignalR: builder => builder.withUrl('_blazor', { transport: 1, skipNegotiation: true })
            }
        });
    </script>
}
else
{
    <script src="@Assets["_framework/blazor.web.js"]"></script>
}
</body>

</html>
