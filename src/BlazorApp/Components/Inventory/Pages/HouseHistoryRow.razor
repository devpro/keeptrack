@* One row of the house history sheet - a compact summary of the most important fields. Editing happens
   through the same modal used to add a new entry (HouseDetail.razor), opened via the Edit button below.
   Edit/delete icons default to text presentation (no FE0F) - same convention as HealthRecordRow.razor. *@

<tr>
    <td>@Entry.HistoryDate.ToString("yyyy-MM-dd")</td>
    <td>@Entry.EventType</td>
    <td>@Entry.Cost?.ToString("F2")</td>
    <td class="d-none d-md-table-cell">@Entry.Provider</td>
    <td class="d-none d-md-table-cell">@Entry.Description</td>
    <td>
        <div class="d-flex gap-1 justify-content-end">
            <button class="kt-icon-btn" title="Edit this entry" aria-label="Edit this entry" @onclick="() => OnEdit.InvokeAsync(Entry)">✎</button>
            <button class="kt-icon-btn" title="Delete this entry" aria-label="Delete this entry" @onclick="() => OnDelete.InvokeAsync(Entry.Id!)">✕</button>
        </div>
    </td>
</tr>

@code {
    [Parameter] public required HouseHistoryDto Entry { get; set; }

    [Parameter] public EventCallback<HouseHistoryDto> OnEdit { get; set; }

    [Parameter] public EventCallback<string> OnDelete { get; set; }
}
