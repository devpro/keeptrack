@typeparam TDto where TDto : IHasId

@if (Error is not null)
{
    <div class="alert alert-danger mb-4" role="alert">@Error</div>
}

<ConfirmModal Show="_pendingDeleteId is not null"
              Title="Delete this item?"
              Message="@($"This will permanently delete this {ItemName ?? "item"}. This can't be undone.")"
              OnConfirm="ConfirmDeleteAsync" OnCancel="CancelDelete"/>

@if (ShowForm)
{
    <div class="kt-form-card">
        <h5>New @(ItemName ?? "item")</h5>
        <div class="row g-3">
            @FormTemplate(Form)
        </div>
        <div class="d-flex gap-2 mt-3">
            <button class="btn btn-success" @onclick="OnSave">Save</button>
            <button class="btn btn-secondary" @onclick="OnCancelForm">Cancel</button>
        </div>
    </div>
}

@if (Loading)
{
    <div class="kt-loading">
        <div class="kt-spinner"></div>
        Loading your collection…
    </div>
}
else
{
    <div class="kt-table-wrap">
        <div class="kt-table-header">
            <h1 class="kt-table-title">My <span>@Title</span></h1>
            @if (!ShowForm)
            {
                <button class="btn btn-primary" @onclick="OnShowAddForm">+ Add</button>
            }
        </div>
        <div class="kt-search-bar">
            <div class="kt-search-input-wrap">
                <input class="form-control" type="search" placeholder="Search…"
                       @bind="_localSearch" @bind:event="oninput"
                       @onkeyup="HandleSearchKeyUp"/>
                <span class="kt-search-icon">&#128269;</span>
            </div>
            @if (!string.IsNullOrEmpty(_localSearch))
            {
                <button class="btn btn-secondary btn-sm" @onclick="HandleClear">Clear</button>
            }
            <select class="form-select form-select-sm kt-sort-select" title="Sort by" aria-label="Sort by"
                    value="@Sort" @onchange="e => OnSortChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty)">
                <option value="">Added</option>
                <option value="@ListSort.Title">A–Z</option>
                @if (HasRatingSort)
                {
                    <option value="@ListSort.Rating">Rating</option>
                }
            </select>
            @if (Filters is not null)
            {
                <div class="kt-search-filters">@Filters</div>
            }
        </div>
        @if (Items.Count > 0)
        {
            <div class="kt-item-list">
                @foreach (var item in Items)
                {
                    @* The stretched-link title makes the whole row open the detail page (where all editing
                       happens); the delete button sits above it via z-index. *@
                    <div class="kt-item-row">
                        @if (ItemImageUrl is not null)
                        {
                            <ItemThumb ImageUrl="@ItemImageUrl(item)" Shape="@ItemImageShape"/>
                        }
                        <div class="kt-item-main">
                            <a class="kt-item-title stretched-link" href="@($"{Route}/{item.Id}")">@ItemTitle(item)</a>
                            <div class="kt-item-meta">@MetaTemplate(item)</div>
                        </div>
                        <button type="button" class="kt-icon-btn kt-item-delete" title="Delete" aria-label="Delete"
                                @onclick="() => RequestDelete(item)">
                            <TrashIcon/>
                        </button>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="kt-empty">
                <div class="kt-empty-icon">◈</div>
                <p>Your collection is empty.</p>
            </div>
        }

        @if (TotalPages > 1)
        {
            <div class="kt-pagination">
                <button class="kt-page-btn" disabled="@(Page == 1)"
                        @onclick="() => OnGoToPage.InvokeAsync(1)">&#8676;
                </button>
                <button class="kt-page-btn" disabled="@(Page == 1)"
                        @onclick="() => OnGoToPage.InvokeAsync(Page - 1)">&#8592;
                </button>
                @{
                    int start, end;
                    if (TotalPages <= 3)
                    {
                        start = 1;
                        end = TotalPages;
                    }
                    else if (Page <= 2)
                    {
                        start = 1;
                        end = 3;
                    }
                    else if (Page >= TotalPages - 1)
                    {
                        start = TotalPages - 2;
                        end = TotalPages;
                    }
                    else
                    {
                        start = Page - 1;
                        end = Page + 1;
                    }
                }
                @for (var p = start; p <= end; p++)
                {
                    var pageNum = p;
                    <button class="kt-page-btn @(pageNum == Page ? "active" : "")"
                            @onclick="() => OnGoToPage.InvokeAsync(pageNum)">@pageNum</button>
                }
                <button class="kt-page-btn" disabled="@(Page == TotalPages)"
                        @onclick="() => OnGoToPage.InvokeAsync(Page + 1)">&#8594;
                </button>
                <button class="kt-page-btn" disabled="@(Page == TotalPages)"
                        @onclick="() => OnGoToPage.InvokeAsync(TotalPages)">&#8677;
                </button>
                <span class="kt-page-info">@TotalCount results</span>
            </div>
        }
    </div>
}

@code {
    private string? _pendingDeleteId;
    private string _localSearch = "";
    private string _lastSearchParam = "";
    private string _lastSearchSent = "";

    // Adopt an externally-changed Search parameter (URL navigation, browser back/forward) into the
    // input without clobbering in-progress typing: a value we reported ourselves via OnSearchChanged
    // comes straight back as an equal parameter and must be ignored, or a re-render racing fast
    // typing would revert characters entered since the last keyup.
    protected override void OnParametersSet()
    {
        if (Search == _lastSearchParam) return;
        _lastSearchParam = Search;
        if (Search != _lastSearchSent)
        {
            _localSearch = Search;
        }
    }

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        _lastSearchSent = _localSearch;
        await OnSearchChanged.InvokeAsync(_localSearch);
        await OnSearchKeyUp.InvokeAsync(e);
    }

    private async Task HandleClear()
    {
        _localSearch = "";
        _lastSearchSent = "";
        await OnSearchChanged.InvokeAsync("");
        await OnClearSearch.InvokeAsync();
    }

    private void RequestDelete(TDto item) => _pendingDeleteId = item.Id;

    private void CancelDelete() => _pendingDeleteId = null;

    private async Task ConfirmDeleteAsync()
    {
        var id = _pendingDeleteId;
        _pendingDeleteId = null;
        if (id is not null) await OnDelete.InvokeAsync(id);
    }

    [Parameter] public required string Title { get; set; }
    [Parameter] public string? ItemName { get; set; }
    [Parameter] public required List<TDto> Items { get; set; }
    [Parameter] public required TDto Form { get; set; }
    [Parameter] public required bool Loading { get; set; }
    [Parameter] public required bool ShowForm { get; set; }
    [Parameter] public required string? Error { get; set; }
    [Parameter] public required string Search { get; set; }

    /// <summary>Current sort key ("" = the newest-first default) - see <see cref="ListSort"/>.</summary>
    [Parameter] public required string Sort { get; set; }

    /// <summary>Offers the "Rating" sort option - only for types that carry a rating field.</summary>
    [Parameter] public bool HasRatingSort { get; set; }
    [Parameter] public required int Page { get; set; }
    [Parameter] public required int TotalPages { get; set; }
    [Parameter] public required long TotalCount { get; set; }

    /// <summary>The list's own route ("/movies"), also every row link's detail-route prefix.</summary>
    [Parameter] public required string Route { get; set; }

    [Parameter] public required Func<TDto, string?> ItemTitle { get; set; }

    /// <summary>
    /// Cover/poster URL selector - leave unset for types with no reference imagery (cars, houses,
    /// playlists), which then render without a thumbnail column at all.
    /// </summary>
    [Parameter] public Func<TDto, string?>? ItemImageUrl { get; set; }

    /// <summary>See <see cref="ItemThumb.Shape"/>: unset = portrait, "square" (albums), "wide" (games).</summary>
    [Parameter] public string? ItemImageShape { get; set; }

    /// <summary>
    /// The row's second line: year/creator text and .kt-flag-badge pills. This is per-type data shape,
    /// not layout - rows themselves render identically for every type.
    /// </summary>
    [Parameter] public required RenderFragment<TDto> MetaTemplate { get; set; }

    [Parameter] public required RenderFragment<TDto> FormTemplate { get; set; }
    [Parameter] public RenderFragment? Filters { get; set; }
    [Parameter] public required EventCallback OnSave { get; set; }
    [Parameter] public required EventCallback OnCancelForm { get; set; }
    [Parameter] public required EventCallback OnShowAddForm { get; set; }
    [Parameter] public required EventCallback OnClearSearch { get; set; }
    [Parameter] public required EventCallback<KeyboardEventArgs> OnSearchKeyUp { get; set; }
    [Parameter] public required EventCallback<int> OnGoToPage { get; set; }
    [Parameter] public required EventCallback<string> OnDelete { get; set; }
    [Parameter] public required EventCallback<string> OnSearchChanged { get; set; }
    [Parameter] public required EventCallback<string> OnSortChanged { get; set; }
}
