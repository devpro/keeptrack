@for (var i = 1; i <= 5; i++)
{
    var position = i;
    <span class="star @GetStarClass(i)" style="@(OnRatingChanged.HasDelegate ? "cursor:pointer" : "")" @onclick="() => HandleClickAsync(position)">★</span>
}

@code {
    [Parameter] public float? Rating { get; set; }

    /// <summary>
    /// When bound, clicking a star sets the rating to that position - unbound (the default), the
    /// component stays display-only, same as every existing usage.
    /// </summary>
    [Parameter] public EventCallback<float> OnRatingChanged { get; set; }

    private string GetStarClass(int position)
    {
        var rating = Rating ?? 0;
        if (rating >= position) return "full";
        return rating >= position - 0.5f ? "half" : "empty";
    }

    private async Task HandleClickAsync(int position)
    {
        if (!OnRatingChanged.HasDelegate) return;
        await OnRatingChanged.InvokeAsync(position);
    }
}
