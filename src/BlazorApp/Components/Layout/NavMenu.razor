<div class="top-row">
    <a class="navbar-brand" href="">Keeptrack</a>
    <label class="navbar-toggler-label" for="nav-toggle">&#9776;</label>
</div>

<input type="checkbox" id="nav-toggle" />

<div class="nav-scrollable">
    <nav class="nav flex-column">
        <div class="nav-item">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-icon">⌂</span> Home
            </NavLink>
        </div>
        <AuthorizeView>
            <Authorized>
                <div class="nav-item">
                    <NavLink class="nav-link" href="add">
                        <span class="nav-icon">+</span> Quick add
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="watch-next">
                        <span class="nav-icon">▶</span> Watch next
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="wishlist">
                        <span class="nav-icon">○</span> Wishlist
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="movies">
                        <span class="nav-icon">◼</span> Movies
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="tv-shows">
                        <span class="nav-icon">▭</span> TV shows
                    </NavLink>
                </div>
                @* Free preview accounts (no Firebase "member"/"admin" role) only get movies and TV shows - the two links above sit outside this block on purpose.
                   Hiding is UX, not security: the API enforces the same policy on every request. *@
                <AuthorizeView Policy="MemberOnly" Context="memberContext">
                    <Authorized>
                        <div class="nav-item">
                            <NavLink class="nav-link" href="books">
                                <span class="nav-icon">▬</span> Books
                            </NavLink>
                        </div>
                        <div class="nav-item">
                            <NavLink class="nav-link" href="albums">
                                <span class="nav-icon">♪</span> Albums
                            </NavLink>
                        </div>
                        <div class="nav-item">
                            <NavLink class="nav-link" href="playlists">
                                <span class="nav-icon">♫</span> Playlists
                            </NavLink>
                        </div>
                        <div class="nav-item">
                            <NavLink class="nav-link" href="video-games">
                                <span class="nav-icon">◆</span> Video games
                            </NavLink>
                        </div>
                        <div class="nav-item">
                            <NavLink class="nav-link" href="cars">
                                <span class="nav-icon">◉</span> Cars
                            </NavLink>
                        </div>
                        <div class="nav-item">
                            <NavLink class="nav-link" href="houses">
                                <span class="nav-icon">▲</span> Houses
                            </NavLink>
                        </div>
                        <div class="nav-item">
                            <NavLink class="nav-link" href="health">
                                <span class="nav-icon">✚</span> Health
                            </NavLink>
                        </div>
                        <div class="nav-item">
                            <NavLink class="nav-link" href="import">
                                <span class="nav-icon">⬆</span> Import
                            </NavLink>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <div class="nav-item">
                            <span class="kt-nav-note">Preview account - movies &amp; TV shows. A membership unlocks books, albums, games and more.</span>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>
                <AuthorizeView Policy="AdminOnly" Context="adminContext">
                    <Authorized>
                        <div class="nav-item">
                            <NavLink class="nav-link" href="admin/reference-data">
                                <span class="nav-icon">⚙</span> Admin
                            </NavLink>
                        </div>
                    </Authorized>
                </AuthorizeView>
                <div class="nav-divider"></div>
                <div class="nav-item">
                    <a class="nav-link nav-link-user" href="/account/manage">
                        <span class="nav-icon kt-nav-avatar">@(GetInitial(context.User.Identity?.Name))</span>
                        <span class="nav-username">@context.User.Identity?.Name</span>
                    </a>
                </div>
                <div class="nav-item">
                    <a class="nav-link nav-link-logout" href="/auth/logout">
                        <span class="nav-icon">⇥</span> Log out
                    </a>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item">
                    <a class="nav-link" href="/account/login" data-enhance-nav="false">
                        <span class="nav-icon">→</span> Sign in
                    </a>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private static string GetInitial(string? name) =>
        string.IsNullOrEmpty(name) ? "" : name[..1].ToUpperInvariant();
}
