<div class="top-row">
    <a class="navbar-brand" href="">Keeptrack</a>
    <label class="navbar-toggler-label" for="nav-toggle">&#9776;</label>
</div>

<input type="checkbox" id="nav-toggle" />

<div class="nav-scrollable">
    <nav class="nav flex-column">
        <div class="nav-item">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-icon">⌂</span> Home
            </NavLink>
        </div>
        <AuthorizeView>
            <Authorized>
                <div class="nav-item">
                    <NavLink class="nav-link" href="watch-next">
                        <span class="nav-icon">▶</span> Watch next
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="books">
                        <span class="nav-icon">▬</span> Books
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="movies">
                        <span class="nav-icon">◼</span> Movies
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="music-albums">
                        <span class="nav-icon">♪</span> Music albums
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="tv-shows">
                        <span class="nav-icon">▭</span> TV shows
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="video-games">
                        <span class="nav-icon">◆</span> Video games
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="import">
                        <span class="nav-icon">⬆</span> Import
                    </NavLink>
                </div>
                <AuthorizeView Policy="AdminOnly" Context="adminContext">
                    <Authorized>
                        <div class="nav-item">
                            <NavLink class="nav-link" href="admin/reference-data">
                                <span class="nav-icon">⚙</span> Admin
                            </NavLink>
                        </div>
                    </Authorized>
                </AuthorizeView>
                <div class="nav-divider"></div>
                <div class="nav-item">
                    <button type="button" class="nav-link kt-theme-toggle" onclick="ktToggleTheme()">
                        <span class="nav-icon kt-theme-icon-light">☀</span>
                        <span class="nav-icon kt-theme-icon-dark">☾</span>
                        Toggle theme
                    </button>
                </div>
                <div class="nav-item">
                    <a class="nav-link nav-link-user" href="/account/manage">
                        <span class="nav-icon kt-nav-avatar">@(GetInitial(context.User.Identity?.Name))</span>
                        <span class="nav-username">@context.User.Identity?.Name</span>
                    </a>
                </div>
                <div class="nav-item">
                    <a class="nav-link nav-link-logout" href="/auth/logout">
                        <span class="nav-icon">⇥</span> Log out
                    </a>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item">
                    <a class="nav-link" href="/account/login" data-enhance-nav="false">
                        <span class="nav-icon">→</span> Sign in
                    </a>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private static string GetInitial(string? name) =>
        string.IsNullOrEmpty(name) ? "" : name[..1].ToUpperInvariant();
}
