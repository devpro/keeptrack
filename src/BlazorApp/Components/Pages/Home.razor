@page "/"
@inject StatsApiClient StatsApi

<PageTitle>Keeptrack</PageTitle>

<div class="kt-home">
    <AuthorizeView>
        <Authorized>
            <div class="kt-home-eyebrow">Your personal collection</div>
            @if (_stats is not null && TotalItems > 0)
            {
                <h1>Welcome back —<br/><em>@TotalItems.ToString("N0") things remembered.</em></h1>
                <p class="kt-home-sub">
                    Good work building this up@(_stats.EpisodesWatched > 0 ? $" — including {_stats.EpisodesWatched:N0} episodes watched across your shows" : "").
                    Every entry below is one more thing you'll never lose.
                </p>
                <div class="kt-stat-grid">
                    <a class="kt-stat-tile" href="/movies"><span class="kt-stat-value">@_stats.Movies</span><span class="kt-stat-label">Movies</span></a>
                    <a class="kt-stat-tile" href="/tv-shows"><span class="kt-stat-value">@_stats.TvShows</span><span class="kt-stat-label">TV shows</span></a>
                    <a class="kt-stat-tile" href="/books"><span class="kt-stat-value">@_stats.Books</span><span class="kt-stat-label">Books</span></a>
                    <a class="kt-stat-tile" href="/albums"><span class="kt-stat-value">@_stats.Albums</span><span class="kt-stat-label">Albums</span></a>
                    <a class="kt-stat-tile" href="/video-games"><span class="kt-stat-value">@_stats.VideoGames</span><span class="kt-stat-label">Video games</span></a>
                    <a class="kt-stat-tile" href="/playlists"><span class="kt-stat-value">@_stats.Playlists</span><span class="kt-stat-label">Playlists</span></a>
                    <a class="kt-stat-tile" href="/cars"><span class="kt-stat-value">@_stats.Cars</span><span class="kt-stat-label">Cars</span></a>
                    <a class="kt-stat-tile" href="/houses"><span class="kt-stat-value">@_stats.Houses</span><span class="kt-stat-label">Houses</span></a>
                </div>
            }
            else
            {
                <h1>Everything you do,<br/><em>remembered.</em></h1>
                <p class="kt-home-sub">
                    Your collection is waiting for its first entry - log a film watched, a book read, an album on repeat.
                    Rate it, note it, never lose it.
                </p>
                <div class="kt-home-cta">
                    <a class="btn btn-primary" href="/add">+ Quick add</a>
                    <a class="btn btn-secondary" href="/movies">Go to my movies</a>
                </div>
            }
        </Authorized>
        <NotAuthorized>
            <div class="kt-home-eyebrow">Your personal collection</div>
            <h1>Everything you do,<br/><em>remembered.</em></h1>
            <p class="kt-home-sub">
                Keeptrack is your quiet space to log the things that matter - films watched, books read, places visited, habits tracked.
                Rate them, note them, never lose them.
            </p>

            <div class="kt-home-features">
                <span class="kt-home-feature">◼ Movies</span>
                <span class="kt-home-feature">▭ TV Shows</span>
                <span class="kt-home-feature">▬ Books</span>
                <span class="kt-home-feature">▲ Refueling</span>
                <span class="kt-home-feature">+ more</span>
            </div>

            <div class="kt-home-cta">
                <a class="btn btn-primary" href="/account/login" data-enhance-nav="false">Get started</a>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthenticationState { get; set; }

    private CollectionStatsDto? _stats;

    private long TotalItems =>
        _stats is null
            ? 0
            : _stats.Movies + _stats.TvShows + _stats.Books + _stats.Albums + _stats.VideoGames + _stats.Playlists + _stats.Cars + _stats.Houses;

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationState is null) return;

        var authState = await AuthenticationState;
        if (authState.User.Identity?.IsAuthenticated != true) return;

        try
        {
            _stats = await StatsApi.GetAsync();
        }
        catch (Exception)
        {
            // the greeting is decoration - a stats hiccup must never break the landing page, so it just falls back to the CTA variant
        }
    }
}
