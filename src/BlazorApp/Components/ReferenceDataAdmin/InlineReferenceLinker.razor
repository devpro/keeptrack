@inject ReferenceDataAdminApiClient Api

<AuthorizeView Policy="AdminOnly" Context="adminContext">
    <Authorized>
        <div class="kt-form-card">
            <p class="kt-card-meta mb-2">Not yet matched to a reference source (admin only).</p>

            @if (Type == ReferenceItemType.Book && _bookProviders.Count > 0)
            {
                <div class="d-flex gap-2 flex-wrap mb-2">
                    @foreach (var bookProvider in _bookProviders)
                    {
                        <button type="button" class="btn btn-sm @(bookProvider.Key == _selectedProvider ? "btn-primary" : "btn-secondary")"
                                @onclick="() => _selectedProvider = bookProvider.Key">@bookProvider.DisplayName</button>
                    }
                </div>
            }

            @* One persistent button for search/re-search, re-labeled rather than swapped out for a
               differently-labeled button after the first search - it used to be replaced by a plain
               "↻ Search again" button post-search, which looked like the original button had vanished.
               Re-runs with the page's *current* title/year (and author/artist) field values - the
               wrong-candidates fix is "edit the fields above, then search again". *@
            <button class="btn btn-sm btn-secondary mb-2" @onclick="SearchAsync" disabled="@(_searching || string.IsNullOrWhiteSpace(Title))">
                @(_searched ? "↻ Search again" : "Search")
            </button>

            @if (_searching)
            {
                <div class="kt-loading"><div class="kt-spinner"></div> Searching…</div>
            }
            else if (_searched && _results.Count == 0)
            {
                <div class="alert alert-info mb-2">No @ProviderName results for this title/year.</div>
            }
            else
            {
                @foreach (var candidate in _results)
                {
                    <div class="d-flex align-items-center gap-2 mb-2">
                        @if (!string.IsNullOrEmpty(candidate.ImageUrl))
                        {
                            <img src="@candidate.ImageUrl" alt="@candidate.Title poster"
                                 style="width:40px;height:60px;object-fit:cover;flex-shrink:0" class="rounded"/>
                        }
                        <div>
                            <strong>@candidate.Title</strong> @(candidate.Year is not null ? $"({candidate.Year})" : "")
                            @if (!string.IsNullOrEmpty(candidate.Creator))
                            {
                                <div class="kt-card-meta">@candidate.Creator</div>
                            }
                            @if (candidate.TopCastNames.Count > 0)
                            {
                                <div class="kt-card-meta">@string.Join(", ", candidate.TopCastNames)</div>
                            }
                        </div>
                        <button class="btn btn-sm btn-success ms-auto" @onclick="() => LinkAsync(candidate)" disabled="@_linking">Link</button>
                    </div>
                }
            }

            @if (_error is not null)
            {
                <div class="alert alert-danger mt-2 mb-0">@_error</div>
            }
        </div>
    </Authorized>
</AuthorizeView>

@code {
    [Parameter, EditorRequired] public required ReferenceItemType Type { get; set; }

    [Parameter, EditorRequired] public required string Title { get; set; }

    [Parameter] public int? Year { get; set; }

    /// <summary>
    /// The book's author or the album's artist, when known - narrows the search considerably (a common
    /// title alone often returns many unrelated candidates). Ignored for TV shows/movies/video games.
    /// </summary>
    [Parameter] public string? Creator { get; set; }

    [Parameter] public EventCallback OnLinked { get; set; }

    private bool _searched;
    private bool _searching;
    private bool _linking;
    private List<ReferenceSearchResultDto> _results = [];
    private string? _error;
    private List<BookProviderDto> _bookProviders = [];
    private string? _selectedProvider;

    private string ProviderName => Type switch
    {
        ReferenceItemType.TvShow or ReferenceItemType.Movie => "TMDB",
        ReferenceItemType.Book => _bookProviders.FirstOrDefault(p => p.Key == _selectedProvider)?.DisplayName ?? "Google Books",
        ReferenceItemType.VideoGame => "RAWG",
        ReferenceItemType.Album => "Discogs",
        _ => "reference"
    };

    protected override async Task OnInitializedAsync()
    {
        if (Type != ReferenceItemType.Book) return;
        _bookProviders = await Api.GetBookProvidersAsync();
        _selectedProvider = _bookProviders.FirstOrDefault()?.Key;
    }

    private async Task SearchAsync()
    {
        _searched = true;
        _searching = true;
        _error = null;
        try
        {
            _results = await Api.SearchAsync(Type, Title, Year, Creator, Type == ReferenceItemType.Book ? _selectedProvider : null);
        }
        catch (Exception ex)
        {
            // an uncaught exception here would crash the whole Blazor Server circuit (not just this
            // component), forcing a full page reload - same reasoning as LinkAsync's own try/catch below.
            _results = [];
            _error = ex.Message;
        }
        finally
        {
            _searching = false;
        }
    }

    private async Task LinkAsync(ReferenceSearchResultDto candidate)
    {
        _linking = true;
        _error = null;
        try
        {
            await Api.LinkAsync(new LinkReferenceRequestDto
            {
                Type = Type,
                Title = Title,
                Year = Year,
                ExternalId = candidate.ExternalId,
                Provider = Type == ReferenceItemType.Book ? _selectedProvider : null
            });
            await OnLinked.InvokeAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _linking = false;
        }
    }
}
